DATABASE_URL=sqlite+aiosqlite:///./data/ai_interviewer.db
UPLOAD_DIR=./uploads
LOG_DIR=./logs
AI_SERVICE_MODE=mock
MAX_DAILY_INTERVIEWS=3
MAX_FOLLOW_UP_COUNT=2
ANSWER_TIMEOUT_SECONDS=30
INTERVIEW_RECOVERY_HOURS=24
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# LLM (Qwen3-235B, OpenAI-compatible)
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=Qwen3-235B
LLM_TIMEOUT=60
LLM_MAX_TOKENS=2048

# OCR / Vision (Qwen2-VL-72B)
OCR_API_URL=
OCR_API_KEY=
OCR_MODEL=Qwen2-VL-72B
OCR_TIMEOUT=30

# DashScope (ASR + TTS)
DASHSCOPE_API_KEY=
ASR_MODEL=paraformer-v2
TTS_MODEL=cosyvoice-v2
TTS_VOICE=longxiaochun
TTS_FORMAT=wav
